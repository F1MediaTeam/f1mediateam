# Copy to .env.local. Leave blank for the localhost mock mode.

# === Supabase (production) — leave empty in dev to use the mock store ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Google OAuth (for GSC + GA4 connectors, Phase 1.x) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# === Token-at-rest encryption (AES-256-GCM, encrypts OAuth tokens before storing in Postgres) ===
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# === Cron auth (Vercel cron) ===
CRON_SECRET=

# === Email provider (Resend, Postmark, etc. — Phase 1 email/opt-out) ===
EMAIL_API_KEY=
EMAIL_FROM=hello@f1media.dev
